{
  "version": 2,
  "functions": {
    "api/index.py": {
      "runtime": "python3.11"
    }
  },
  "experimentalServices": [
    {
      "name": "backend",
      "src": "backend",
      "buildCommand": "pip install -r backend/requirements.txt",
      "startCommand": "gunicorn -k uvicorn.workers.UvicornWorker backend.main:app --bind 0.0.0.0:$PORT"
    }
  ],
  "routes": [
    {
      "src": "^/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
